# Exemplo de arquivo .env para o Vite
# Copie este arquivo para .env.local para configurar suas variáveis de ambiente

# URL da API (opcional - padrão: /api com proxy)
# VITE_API_URL=http://localhost:8080/api

# Modo de desenvolvimento (definido automaticamente pelo Vite)
# DEV=true (em modo dev)
# PROD=true (em build de produção)
